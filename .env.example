# Copy to .env and fill in. Loaded by config.py (pydantic-settings).

# --- OpenRouter (chat model) ---
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Confirm the exact slug on https://openrouter.ai/models (DeepSeek family).
OPENROUTER_MODEL=deepseek/deepseek-chat
# Optional separate cheaper model for routing/grading; defaults to OPENROUTER_MODEL.
OPENROUTER_FAST_MODEL=deepseek/deepseek-chat
# OpenRouter attribution headers (optional but recommended)
OPENROUTER_APP_URL=http://localhost:8000
OPENROUTER_APP_TITLE=ATO Tax-Return Knowledge Engine
# DeepSeek thinking/reasoning tokens off (lower latency). Set true to re-enable.
REASONING_ENABLED=false

# --- Database ---
DATABASE_URL=postgresql://ato:ato@localhost:5433/ato_kb

# --- Corpus / indexing ---
# Latest income year present in the data (year folder = year ending 30 June).
CURRENT_TAX_YEAR=2026
DATA_DIR=../output

# --- Embeddings (via OpenRouter; qwen3-embedding-8b is 4096-dim, supports MRL) ---
EMBED_MODEL=qwen/qwen3-embedding-8b
EMBED_DIM=4096

# --- Reranker (via OpenRouter /rerank, Cohere) ---
RERANK_MODEL=cohere/rerank-4-fast

# --- Retrieval knobs ---
HYBRID_TOP_K=40          # candidates pulled from each of dense + sparse before fusion
RERANK_TOP_N=8           # chunks kept after rerank
RETRIEVE_MAX_ROUNDS=2    # CRAG re-query cap
VERIFY_MAX_ROUNDS=1      # grounding re-synthesis cap
